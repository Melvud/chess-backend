{
  "name": "chess-analysis-backend",
  "version": "1.0.0",
  "description": "Chess analysis backend with Stockfish",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p . && tsc-alias -p tsconfig.json",
    "start": "bash scripts/start.sh",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "chess",
    "stockfish",
    "analysis"
  ],
  "author": "Melvud",
  "license": "MIT",
  "dependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "chess.js": "^1.0.0-beta.8",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "multer": "^2.1.1",
    "pino": "^8.16.2",
    "pino-http": "^8.5.1",
    "concurrently": "^9.2.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/multer": "^2.1.0",
    "tsc-alias": "^1.8.8",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
